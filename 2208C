#include <iostream>
#include <vector>
#include <iomanip>
using namespace std;

int main(){
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;

        vector<long double> c(n);
        vector<long double> p(n);

        for(int i=0; i<n; i++){
            cin>>c[i];
            cin>>p[i];
        }
        long double best_ans = c[n-1];
        for(int i=n-2; i>=0; i--){
            best_ans = max(best_ans, best_ans*(1-p[i]/100.0)+c[i]);
        }
        cout << fixed << setprecision(10) << best_ans << '\n';    }
}
