#include <iostream>
#include <vector>
using namespace std;

int main(){
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;
        vector<long long> f(n);
        for(int i=0; i<n; i++)
        cin>>f[i];
        vector<long long> arr(n);
        for (int i=1; i<n-1; i++){
            arr[i] = (2*f[i]-f[i-1]-f[i+1])/-2;
            // cout<<arr[i]<<" ";
        }
        
        arr[0] = ((f[0]+f[n-1])/(n-1) + f[1] - f[0])/2;
        arr[n-1] = (f[n-1] - f[n-2] -  (f[0]+f[n-1])/(n-1))/-2;

        for (int i=0; i<n; i++){
            cout<<arr[i]<<" ";
        }
        cout<<endl;

    }
}
